# Copy to .env and fill values.

# Execution
DRY_RUN=true
DATA_SOURCE=mock

# Notion (required when DRY_RUN=false)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Kiwoom (required when DATA_SOURCE=kiwoom)
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
KIWOOM_BASE_URL=https://api.kiwoom.com

# Optional: if empty, token is issued automatically by APP_KEY/APP_SECRET.
KIWOOM_ACCESS_TOKEN=

# Optional: custom endpoint that returns {"items":[...]}.
# If empty, built-in Kiwoom rank API is used.
KIWOOM_CANDIDATES_URL=

# Built-in Kiwoom rank API options (/api/dostk/rkinfo)
KIWOOM_RANK_API_ID=ka10020
KIWOOM_MRKT_TP_LIST=001,101
KIWOOM_SORT_TP=3
KIWOOM_TRDE_QTY_TP=00100
KIWOOM_STK_CND=1
KIWOOM_CRD_CND=0
KIWOOM_STEX_TP=1
KIWOOM_FALLBACK_MARKET_CAP=300000000000

# Filters
MIN_CHANGE_PCT=2
MAX_CHANGE_PCT=25
MIN_TRADE_VALUE=10000000000
MIN_MARKET_CAP=300000000000
EXCLUDE_KEYWORDS=ETF,ETN,스팩,SPAC
MAX_RESULTS=20
